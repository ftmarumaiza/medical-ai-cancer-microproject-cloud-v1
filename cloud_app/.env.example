# Model settings
MODEL_PATH=../yolov8n.pt
DEVICE=cpu
CONFIDENCE_THRESHOLD=0.25
IOU_THRESHOLD=0.45
MAX_IMAGE_DIM=640

# Cancer decision settings
CANCER_LABEL_KEYWORDS=cancer,tumor,tumour,polyp,lesion,malignant,neoplasm,adenoma
CANCER_POSITIVE_LABELS=polyp,0,bed
CANCER_DECISION_CONFIDENCE=0.25

# Storage settings: local or s3
STORAGE_MODE=local
S3_BUCKET_NAME=
S3_REGION=us-east-1
S3_PREFIX=medical-uploads

